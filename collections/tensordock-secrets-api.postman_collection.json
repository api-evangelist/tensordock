  "info": {
    "_postman_id": "fe472157-c9f3-43b5-81fc-f7644e9fd9b5",
    "name": "TensorDock Secrets API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The TensorDock Secrets API (v2) for managing SSH keys and generic secrets\nthat can be attached to instances at deploy time. Secrets are encrypted at\nrest and in transit. Two types are supported: `SSHKEY` for SSH access and\n`GENERIC` / `SECRET` for opaque application credentials whose `value` is\nnever returned after creation.\n\n\nContact Support:\n Name: TensorDock Support\n Email: support@tensordock.com",
      "type": "text/plain"
    }
  }
